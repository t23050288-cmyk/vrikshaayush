<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_cream">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/primary_green"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">
        <Button
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:backgroundTint="@android:color/transparent"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Crop Disease Library"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Search -->
    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="12dp"
        android:hint="🔍  Search disease or crop..."
        android:background="@color/white"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textSize="14sp"
        android:inputType="text"/>

    <!-- Crop Filter Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="8dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="All"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary_green"
                android:layout_marginEnd="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>

            <Button
                android:id="@+id/chipTomato"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🍅 Tomato"
                android:textSize="12sp"
                android:textColor="@color/primary_green"
                android:backgroundTint="@color/primary_green_light"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/chipRice"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🌾 Rice"
                android:textSize="12sp"
                android:textColor="@color/primary_green"
                android:backgroundTint="@color/primary_green_light"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/chipWheat"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🌿 Wheat"
                android:textSize="12sp"
                android:textColor="@color/primary_green"
                android:backgroundTint="@color/primary_green_light"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/chipCotton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Cotton"
                android:textSize="12sp"
                android:textColor="@color/primary_green"
                android:backgroundTint="@color/primary_green_light"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/chipMaize"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🌽 Maize"
                android:textSize="12sp"
                android:textColor="@color/primary_green"
                android:backgroundTint="@color/primary_green_light"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDiseases"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

</LinearLayout>
